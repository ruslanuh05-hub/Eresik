# Токен бота Telegram (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (для уведомлений о платежах)
ADMIN_IDS=123456789,987654321

# FreeKassa (https://docs.freekassa.net/)
FREKASSA_SHOP_ID=12345
FREKASSA_SECRET_1=secret_word_1
FREKASSA_SECRET_2=secret_word_2

# Публичный URL вашего сервера (для callback FreeKassa, ссылок подписки и страниц импорта /open/...)
# Пример: https://yourdomain.com или https://jvpn-bot.onrender.com
# Если задан — бот использует webhook (для Render), иначе — polling (локально)
PUBLIC_BASE_URL=https://yourdomain.com
# Опционально: отдельный базовый URL для HTTPS-кнопок импорта (по умолчанию = PUBLIC_BASE_URL)
# IMPORT_BRIDGE_BASE=https://yourdomain.com
# Как отображать бота в политике/соглашении
PUBLIC_BOT_DISPLAY=@jetvpnpro_bot

# База данных
# Render: DATABASE_URL создаётся автоматически при добавлении PostgreSQL
# Локально: оставьте пустым — будет SQLite
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATA_DIR=./data

# Ссылка на подписку HAP (отдаётся пользователям)
SUBSCRIPTION_BASE_URL=https://sub1.jetstoreapp.ru/v2raytun-sub
